<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.excel-auditor.dev-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>__INSTALL_ROOT__/server/run-server.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__INSTALL_ROOT__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/.config/excel-auditor/logs/server.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/.config/excel-auditor/logs/server-error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
